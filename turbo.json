{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig*.json", "tsdown.config.ts", "bin/**"],
      "outputs": ["dist/**"]
    },
    "test": {
      "inputs": ["src/**", "test/**", "test-utils/**", "tsconfig*.json"],
      "cache": true
    },
    "lint": {
      "inputs": ["src/**", "test/**", "{workspaceRoot}/biome.json"],
      "cache": true
    },
    "e2e": {
      "dependsOn": ["^build"],
      "cache": false
    }
  }
}
